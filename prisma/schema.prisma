  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([category])
  @@map("memories")
}

model MemoryEmbedding {
  id        String   @id @default(uuid()) @db.Uuid
