datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Theme {
  LIGHT
  DARK
  AMOLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum HabitFrequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  authProvider    String           @default("CLERK")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profile         Profile?
  settings        Settings?
  notifications   Notification[]
  tasks           Task[]
  labels          Label[]
  habits          Habit[]
  goals           Goal[]
  folders         Folder[]
  tags            Tag[]
  notes           Note[]
  calendarEvents  CalendarEvent[]
  healthProfile   HealthProfile?
  waterLogs       WaterLog[]
  sleepLogs       SleepLog[]
  workouts        Workout[]
  weightLogs      WeightLog[]
  medications     Medication[]
  cycles          Cycle[]
  pcosLogs        PCOSLog[]
  hairRoutines    HairRoutine[]
  hairLogs        HairLog[]
  skinRoutines    SkinRoutine[]
  skinLogs        SkinLog[]
  moodLogs        MoodLog[]
  healthGoals     HealthGoal[]
  healthReminders HealthReminder[]

  @@map("users")
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String?
  avatar      String?
  dateOfBirth DateTime?
  gender      String?
  timezone    String    @default("UTC")
  country     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("profiles")
}

model Settings {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             Theme    @default(DARK)
  marketingEmails   Boolean  @default(false)
  securityAlerts    Boolean  @default(true)
  pushNotifications Boolean  @default(true)
  currency          String   @default("USD")
  language          String   @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("settings")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  type      String   @default("SYSTEM")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ==========================================
// PRODUCTIVITY MODULE MODELS
// ==========================================

model Task {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @db.Uuid
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  description       String?    @db.Text
  status            TaskStatus @default(TODO)
  priority          Priority   @default(MEDIUM)
  dueDate           DateTime?
  startDate         DateTime?
  time              String?    // e.g. "14:30"
  estimatedDuration Int?       // in minutes
  color             String?    // hex color
  icon              String?    // lucide icon name
  pinned            Boolean    @default(false)
  favorite          Boolean    @default(false)
  recurringExpr     String?    // e.g., "every 1 day" or CRON pattern
  goalId            String?    @db.Uuid
  goal              Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  subtasks          Subtask[]
  labels            Label[]    @relation("TaskLabels")
  
  // Self-referential relation for task dependencies
  dependsOnId       String?    @db.Uuid
  dependsOn         Task?      @relation("TaskDependencies", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependencies      Task[]     @relation("TaskDependencies")

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model Subtask {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@map("subtasks")
}

model Label {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   // Hex code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]   @relation("TaskLabels")

  @@unique([userId, name])
  @@map("labels")
}

model Habit {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  frequency    HabitFrequency @default(DAILY)
  customFreq   String?        // JSON representation of custom frequency rules
  reminderTime String?        // e.g. "08:00"
  streak       Int            @default(0)
  category     String         @default("Personal")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  logs         HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id          String   @id @default(uuid()) @db.Uuid
  habitId     String   @db.Uuid
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([habitId, completedAt])
  @@map("habit_logs")
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String     @default("General")
  progress    Int        @default(0) // progress percentage or raw count
  target      Int        @default(100) // target value, e.g. 100 for percentage
  deadline    DateTime?
  status      GoalStatus @default(ACTIVE)
  priority    Priority   @default(MEDIUM)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  milestones  Milestone[]
  tasks       Task[]

  @@index([userId])
  @@map("goals")
}

model Milestone {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @db.Uuid
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
  @@map("milestones")
}

model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     Note[]

  @@unique([userId, name])
  @@map("folders")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     Note[]   @relation("NoteTags")

  @@unique([userId, name])
  @@map("tags")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String?  @db.Text // Markdown text
  pinned    Boolean  @default(false)
  folderId  String?  @db.Uuid
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tags      Tag[]    @relation("NoteTags")

  @@index([userId])
  @@map("notes")
}

model CalendarEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?  @db.Text
  start         DateTime
  end           DateTime
  allDay        Boolean  @default(false)
  recurringRule String?  // e.g. "FREQ=WEEKLY;BYDAY=MO,WE,FR"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([start, end])
  @@map("calendar_events")
}

model HealthProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  height       Float?
  weight       Float?
  targetWeight Float?
  waterGoal    Int?     @default(2000) // in ml
  sleepGoal    Float?   @default(8.0)  // in hours
  workoutGoal  Int?     @default(150)  // in minutes per week
  cycleGoal    Int?     @default(28)   // in days
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("health_profiles")
}

model WaterLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // in ml
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("water_logs")
}

model SleepLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  duration  Float    // in hours
  quality   Int      // 1 to 5 rating
  notes     String?  @db.Text
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("sleep_logs")
}

model Workout {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String            // e.g. Strength, Cardio, Yoga, etc.
  duration  Int               // in minutes
  calories  Int?              // placeholder
  notes     String?           @db.Text
  date      DateTime          @default(now())
  exercises WorkoutExercise[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
  @@index([date])
  @@map("workouts")
}

model WorkoutExercise {
  id        String   @id @default(uuid()) @db.Uuid
  workoutId String   @db.Uuid
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name      String
  sets      Int?
  reps      Int?
  weight    Float?   // in kg
  duration  Int?     // in seconds
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workoutId])
  @@map("workout_exercises")
}

model WeightLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float    // in kg
  bmi       Float?   // body mass index
  chest     Float?   // in cm
  waist     Float?   // in cm
  hips      Float?   // in cm
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("weight_logs")
}

model Medication {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  dosage           String          // e.g. "500mg" or "1 pill"
  schedule         String          // e.g. "Morning", "Night", or "14:30"
  frequency        String          // e.g. "DAILY", "WEEKLY", "AS_NEEDED"
  startDate        DateTime
  endDate          DateTime?
  remindersEnabled Boolean         @default(true)
  refillReminder   Boolean         @default(false)
  active           Boolean         @default(true)
  logs             MedicationLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@map("medications")
}

model MedicationLog {
  id           String     @id @default(uuid()) @db.Uuid
  medicationId String     @db.Uuid
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  takenAt      DateTime   @default(now())
  status       String     @default("TAKEN") // TAKEN, MISSED, SKIPPED
  notes        String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([medicationId])
  @@map("medication_logs")
}

model Cycle {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime?
  cycleLength Int?
  symptoms    CycleSymptom[]
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@map("cycles")
}

model CycleSymptom {
  id        String   @id @default(uuid()) @db.Uuid
  cycleId   String   @db.Uuid
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  name      String   // e.g. Cramps, Headache, Bloating, Acne, Mood swings
  severity  String?  // Mild, Moderate, Severe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cycleId])
  @@map("cycle_symptoms")
}

model PCOSLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptoms        String[] // Array of symptoms
  weight          Float?   // kg
  medicationTaken Boolean  @default(false)
  waterIntakeMl   Int?
  exerciseMinutes Int?
  stressLevel     Int?     // 1-5 or 1-10 scale
  notes           String?  @db.Text
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("pcos_logs")
}

model HairRoutine {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  washDays  String[]
  oilDays   String[]
  maskDays  String[]
  products  String[]
  active    Boolean   @default(true)
  logs      HairLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("hair_routines")
}

model HairLog {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId     String?      @db.Uuid
  routine       HairRoutine? @relation(fields: [routineId], references: [id], onDelete: SetNull)
  washDone      Boolean      @default(false)
  oilDone       Boolean      @default(false)
  maskDone      Boolean      @default(false)
  hairFallCount Int?         // tracking hair fall
  notes         String?      @db.Text
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([date])
  @@map("hair_logs")
}

model SkinRoutine {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String    // e.g. Morning, Night
  products  String[]
  concerns  String[]
  active    Boolean   @default(true)
  logs      SkinLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("skin_routines")
}

model SkinLog {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId    String?      @db.Uuid
  routine      SkinRoutine? @relation(fields: [routineId], references: [id], onDelete: SetNull)
  completed    Boolean      @default(false)
  acneSeverity String?      // None, Mild, Moderate, Severe
  notes        String?      @db.Text
  date         DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@index([date])
  @@map("skin_logs")
}

model MoodLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood        String   // e.g. Happy, Sad, Calm, etc.
  energyLevel Int
  stressLevel Int
  notes       String?  @db.Text
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("mood_logs")
}

model HealthGoal {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // WATER, SLEEP, WORKOUT, WEIGHT
  target    Float
  current   Float     @default(0)
  startDate DateTime
  endDate   DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("health_goals")
}

model HealthReminder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // WATER, SLEEP, WORKOUT, MEDICATION, GENERAL
  time      String   // e.g. "08:00"
  days      String[]
  enabled   Boolean  @default(true)
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("health_reminders")
}
