// ==========================================
// PHASE 8 — AUTOMATION & WORKFLOW ENGINE
// ==========================================

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  PAUSED
  DRAFT
}

enum WorkflowTriggerType {
  CRON
  EVENT
  WEBHOOK
  AI_SUGGESTION
  MANUAL
}

enum WorkflowActionType {
  CREATE_TASK
  SCHEDULE_EVENT
  SEND_NOTIFICATION
  DISPATCH_EMAIL
  UPLOAD_MEDIA
  FETCH_WEATHER
  RUN_AI_AGENT
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  PENDING_CONFIRMATION
}

model Workflow {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @db.Uuid
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?             @db.Text
  status       WorkflowStatus      @default(ACTIVE)
  isAiGenerated Boolean            @default(false)
  isDestructive Boolean            @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  triggers     WorkflowTrigger[]
  actions      WorkflowAction[]
  executions   WorkflowExecution[]
  schedules    WorkflowSchedule[]
  variables    WorkflowVariable[]
  conditions   WorkflowCondition[]

  @@index([userId])
  @@index([status])
  @@map("workflows")
}

model WorkflowTrigger {
  id          String              @id @default(uuid()) @db.Uuid
  workflowId  String              @db.Uuid
  workflow    Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type        WorkflowTriggerType
  config      String              @db.Text
  providerId  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workflowId])
  @@map("workflow_triggers")
}

model WorkflowCondition {
  id          String   @id @default(uuid()) @db.Uuid
  workflowId  String   @db.Uuid
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  field       String
  operator    String   @default("EQUALS")
  value       String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workflowId])
  @@map("workflow_conditions")
}

model WorkflowAction {
  id           String             @id @default(uuid()) @db.Uuid
  workflowId   String             @db.Uuid
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type         WorkflowActionType
  orderIndex   Int                @default(0)
  config       String             @db.Text
  providerId   String?
  isDestructive Boolean           @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([workflowId])
  @@map("workflow_actions")
}

model WorkflowExecution {
  id         String          @id @default(uuid()) @db.Uuid
  workflowId String          @db.Uuid
  workflow   Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId     String          @db.Uuid
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     ExecutionStatus @default(RUNNING)
  startedAt  DateTime        @default(now())
  endedAt    DateTime?
  durationMs Int?
  error      String?         @db.Text
  logs       ExecutionLog[]

  @@index([workflowId])
  @@index([userId])
  @@index([status])
  @@map("workflow_executions")
}

model ExecutionLog {
  id          String            @id @default(uuid()) @db.Uuid
  executionId String            @db.Uuid
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  level       String            @default("INFO")
  message     String            @db.Text
  stepIndex   Int?
  createdAt   DateTime          @default(now())

  @@index([executionId])
  @@map("execution_logs")
}

model WorkflowTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  category    String
  description String   @db.Text
  isOfficial  Boolean  @default(true)
  config      String   @db.Text
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_templates")
}

model WorkflowVariable {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  key        String
  value      String   @db.Text
  isSecret   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([workflowId])
  @@map("workflow_variables")
}

model AutomationSetting {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoApproveSafeWorkflows Boolean @default(true)
  confirmDestructive     Boolean  @default(true)
  maxDailyExecutions     Int      @default(100)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("automation_settings")
}

model WorkflowSchedule {
  id            String    @id @default(uuid()) @db.Uuid
  workflowId    String    @db.Uuid
  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cronExpression String
  nextRunAt     DateTime?
  lastRunAt     DateTime?
  isEnabled     Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workflowId])
  @@map("workflow_schedules")
}


